<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/editor_bg"
    tools:context=".MainActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/menu_bar_bg"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/menu_bar_bg"
            app:title="iCOBRA"
            app:titleTextColor="@color/text_bright"
            app:subtitle="NexBytes IDE"
            app:subtitleTextColor="@color/text_dim"
            app:navigationIcon="@drawable/ic_code"
            app:navigationIconTint="@color/accent" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Permission screen -->
        <LinearLayout
            android:id="@+id/permissionContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:background="@color/editor_bg"
            android:visibility="visible"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/shizukuIcon"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:src="@drawable/ic_shield"
                android:tint="@color/accent"
                android:layout_marginBottom="24dp"
                tools:ignore="ContentDescription" />

            <TextView
                android:id="@+id/permissionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Shizuku Permission Required"
                android:textColor="@color/text_bright"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/permissionSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="iCOBRA IDE requires Shizuku to provide elevated Android development capabilities including ADB shell access, package management, and system-level debugging."
                android:textColor="@color/text_dim"
                android:textSize="14sp"
                android:textAlignment="center"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="32dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/grantPermissionBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Grant Shizuku Permission"
                android:textColor="@color/white"
                android:backgroundTint="@color/accent"
                android:paddingHorizontal="32dp"
                android:paddingVertical="12dp"
                app:cornerRadius="8dp"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/openShizukuBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Open Shizuku"
                android:textColor="@color/accent"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="@color/accent"
                android:paddingHorizontal="32dp"
                android:paddingVertical="12dp"
                app:cornerRadius="8dp" />

        </LinearLayout>

        <!-- IDE Container (hidden until permission granted) -->
        <FrameLayout
            android:id="@+id/ideContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- React Native / Expo root view fills this -->
            <FrameLayout
                android:id="@+id/reactNativeRoot"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

        </FrameLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Loading indicator -->
    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/loadingProgress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:indicatorColor="@color/accent"
        app:trackColor="@color/border"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
